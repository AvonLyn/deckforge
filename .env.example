DECKFORGE_WORKSPACE_DIR=.deckforge
DECKFORGE_API_HOST=127.0.0.1
DECKFORGE_API_PORT=3217
DECKFORGE_WEB_ORIGIN=http://localhost:5173

# Optional OpenAI-compatible private model endpoint.
# Mimo default: https://api.xiaomimimo.com/v1 with api-key auth.
LLM_MODE=mock
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_API_KEY=
LLM_MODEL=mimo-v2.5
LLM_AUTH_HEADER=api-key
